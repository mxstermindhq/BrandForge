# Copy to `.env` at repo root. Never commit real secrets.
# The Node API reads this file via `src/server/env.js`.
# The Next app uses `web/.env.local` for NEXT_PUBLIC_* (see bottom).

# ─── Supabase ─────────────────────────────────────────
SUPABASE_URL=                        # Project URL
SUPABASE_ANON_KEY=                   # Public anon key (browser-safe)
SUPABASE_SERVICE_ROLE_KEY=           # Server only — never expose to clients
SUPABASE_STATE_KEY=default           # Optional platform_state partition key

# ─── HTTP / origins ───────────────────────────────────
PORT=3000                            # Node API listen port (Railway/Render set this automatically)
# HOST=0.0.0.0                       # Override listen address (Railway/Render/Fly auto-use 0.0.0.0 via server.js)
PUBLIC_WEB_ORIGIN=http://localhost:3001
# Alias read by env.js if PUBLIC_WEB_ORIGIN unset:
NEXT_PUBLIC_APP_URL=
API_PUBLIC_ORIGIN=http://127.0.0.1:3000

# ─── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ─── Crypto invoices (optional) ───────────────────────
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_SANDBOX=0

# ─── LLM / AI (set at least one provider key as needed) ─
AI_API_KEY=
AI_PROVIDER=
AI_MODEL=
AI_IMAGE_KEY=
AI_OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=

# ─── Cron protection ──────────────────────────────────
CRON_SECRET=
