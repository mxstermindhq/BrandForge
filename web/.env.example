# Copy to web/.env.local — never commit secrets.

# Optional: set to 1 only if you need Cloudflare bindings during `next dev` (see next.config.mjs).
# ENABLE_OPENNEXT_DEV=1

# Canonical public origin of this Next app (Worker URL in prod). Used for Supabase email/OAuth redirect targets.
# NEXT_PUBLIC_APP_URL=https://brandforge.gg

# Browser-visible API origin (OAuth via getApiOrigin(); dev rewrite target).
# Local: API on 3000, Next on 3001 — browser uses same-origin /api (proxied). Production: use your real HTTPS API URL.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# Production (Cloudflare): same-origin /api/* rewrites to this origin. Set at build time and on the Worker for SSR/metadata.
# API_PROXY_DESTINATION=https://your-api.example.com

# Optional: explicitly opt in to proxy rewrites (redundant if API_PROXY_DESTINATION is set).
# NEXT_PUBLIC_USE_API_PROXY=1

# Force browser to call NEXT_PUBLIC_API_URL directly in dev (skip Next /api proxy).
# NEXT_PUBLIC_API_DIRECT=1

# Turn off dev /api rewrites — then set NEXT_PUBLIC_API_DIRECT=1 so the browser hits Node.
# DISABLE_DEV_API_REWRITE=1

# Supabase (public anon key only — never service role here). From Supabase → Project Settings → API.
# Production: Cloudflare Worker Git build env + web/wrangler.jsonc vars (if you use CLI deploy), then redeploy.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
