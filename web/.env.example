# Copy to web/.env.local — never commit secrets.

# Browser-visible: real Node API origin (OAuth via getApiOrigin(); rewrite target in dev).
# Default: API on 3000, Next dev on 3001 — browser uses same-origin /api on3001 (proxied to here).
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# Force browser to call NEXT_PUBLIC_API_URL directly in dev (skip Next /api proxy).
# NEXT_PUBLIC_API_DIRECT=1

# Turn off dev /api rewrites in next.config.mjs — then set NEXT_PUBLIC_API_DIRECT=1 so the browser hits Node.
# DISABLE_DEV_API_REWRITE=1


# Set to 1 on Vercel to same-origin /api/* (see next.config.mjs rewrites + API_PROXY_DESTINATION).
# NEXT_PUBLIC_USE_API_PROXY=1

# Supabase (public anon key only — never service role here)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
