# Browser → existing Node API (default: API on 3000, Next on 3001)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# Root API server (.env): set WEB_APP_ORIGIN=http://localhost:3001 so CORS allows this app's origin.
# Social OAuth (also in API .env): SOCIAL_LINKEDIN_CLIENT_ID, SOCIAL_LINKEDIN_CLIENT_SECRET,
# SOCIAL_X_CLIENT_ID, SOCIAL_X_CLIENT_SECRET, SOCIAL_OAUTH_STATE_SECRET (optional; long random string).
# Run supabase/social_connections.sql once. OAuth redirect URL = {PUBLIC_APP_URL}/api/social/oauth/callback
#
# Canonical browser origin for OAuth + magic-link redirects (production: your Worker URL).
# NEXT_PUBLIC_APP_URL=https://brandforge.gg

# Supabase Dashboard → Authentication → URL configuration:
#   Site URL: must match production (e.g. https://brandforge.gg) — not http://localhost:3000
#   Redirect URLs: http://localhost:3001/auth/callback  https://brandforge.gg/auth/callback  (wildcard ok)

# Same values as Supabase project (or fetch once from GET /api/auth/config in dev)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
